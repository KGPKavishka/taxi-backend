generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  role      String
  createdAt DateTime @default(now())
}

model Driver {
  id            Int      @id @default(autoincrement())
  name          String
  vehicleNumber String   @unique
  latitude      Float
  longitude     Float
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
}